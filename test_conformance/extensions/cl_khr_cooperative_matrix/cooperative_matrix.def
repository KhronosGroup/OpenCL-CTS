#ifndef COOPMAT
#error "Define COOPMAT(opname, kind) before including this file"
#endif

// List of operations on cooperative_matrix types.

// Length operation.
COOPMAT(length, Unary)

// Construct constant cooperative matrix.
COOPMAT(constant, Unary)

// Load cooperative matrix from memory, then store back to memory.
COOPMAT(copy, Unary)

// Load cooperative matrix with stride zero from memory, then store back to memory.
COOPMAT(copy_stride0, Unary)

// Load/store cooperative matrix from workgroup/local memory.
COOPMAT(copy_workgroup, Unary)

// Convert/bitcast between supported cooperative matrix types.
COOPMAT(convert, Conversion)

// Construct cooperative matrix from composite.
COOPMAT(composite, Unary)
COOPMAT(composite_array, Unary)
COOPMAT(composite_rvalue, Unary)

// Element-wise arithmetic operations.
COOPMAT(negate, Unary)
COOPMAT(add, Binary)
COOPMAT(sub, Binary)
COOPMAT(mul, Binary)
COOPMAT(div, Binary)

// Matrix multiply-accumulate.
COOPMAT(matrixmuladd, Ternary)
COOPMAT(matrixmuladd_array, Ternary)
COOPMAT(matrixmuladd_saturating, Ternary)
COOPMAT(matrixmuladd_wrapping, Ternary)
COOPMAT(matrixmuladd_stride0, Ternary)

// Load/store from/into vector types.
COOPMAT(multicomponent_load, Unary)
COOPMAT(multicomponent_store, Unary)

// Cooperative matrix type as user function argument.
COOPMAT(func, Unary)
